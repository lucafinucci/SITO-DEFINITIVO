# Database Configuration
DB_HOST=localhost
DB_NAME=finch_ai_clienti
DB_USER=root
DB_PASS=

# Security
SESSION_LIFETIME=7200
CSRF_TOKEN_LIFETIME=3600

# Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# API Configuration
KPI_API_ENDPOINT=https://app.finch-ai.it/api/kpi/documenti
KPI_API_KEY=

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
VITE_AREA_CLIENTI_URL=/area-clienti/login.php

# MFA/TOTP
MFA_ISSUER=Finch-AI
MFA_DIGITS=6
MFA_PERIOD=30

# =========================
# Chatbot RAG
# =========================
# Una sola chiave OPENAI_API_KEY è sufficiente per local dev.
# In produzione consigliamo DUE chiavi distinte (gestite separatamente):
#
#   1) BUILD-TIME — secret GitHub `OPENAI_API_KEY_BUILD`
#      Usata dal workflow .github/workflows/deploy-aruba.yml allo step
#      "Build RAG index". Calcola embeddings dei contenuti del sito una sola
#      volta per deploy (~0.001$). Quota richiesta: minima.
#
#   2) RUNTIME — variabile su Aruba in /www.finch-ai.it/.env
#      Letta da area-clienti/api/chat/chat.php a ogni richiesta utente per:
#        - embed della query (text-embedding-3-small)
#        - chat completion streaming (gpt-4o-mini)
#      Quota richiesta: in linea col traffico atteso.
#      Tienila isolata: se trapela, ruoti solo quella senza ricostruire l'indice.
#
OPENAI_API_KEY=

# Sicurezza & rate limit (runtime)
CHAT_RATE_LIMIT_PER_MIN=20
CHAT_RATE_LIMIT_PER_DAY=100
CHAT_ALLOWED_ORIGINS=https://finch-ai.it,https://www.finch-ai.it
# Salt per hash IP nei log (qualunque stringa lunga e segreta)
CHAT_IP_SALT=

# Override path indice (opzionale; default risolto automaticamente)
# RAG_INDEX_PATH=/var/www/finch-ai.it/rag/chunks.json

# Frontend override (opzionale; default /area-clienti/api/chat/chat.php)
# VITE_CHAT_ENDPOINT=/area-clienti/api/chat/chat.php
